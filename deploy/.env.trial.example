BOTREE_BASE_DIR=/data/botree
DOCKER_NETWORK=botree-trial

API_IMAGE=botree/backend-api:trial
WORKER_IMAGE=botree/backend-worker:trial
MODEL_SERVICE_IMAGE=botree/backend-api:trial
API_CONTAINER_NAME=botree-api
WORKER_CONTAINER_NAME=botree-worker
MODEL_SERVICE_CONTAINER_NAME=botree-model-service
API_PORT=18888
BACKEND_CONTAINER_PORT=8888
MODEL_SERVICE_PORT=8890
MODEL_SERVICE_USE_GPU=true

MYSQL_IMAGE=mysql:8.4
MYSQL_CONTAINER_NAME=botree-mysql
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PORT=3306
MYSQL_DATA_DIR=/data/botree/mysql

REDIS_IMAGE=redis:7.4
REDIS_CONTAINER_NAME=botree-redis
REDIS_PORT=6379
REDIS_DATA_DIR=/data/botree/redis

MINIO_IMAGE=minio/minio:latest
MINIO_CONTAINER_NAME=botree-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=/data/botree/minio

MILVUS_IMAGE=milvusdb/milvus:v2.4.22
MILVUS_CONTAINER_NAME=botree-milvus
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_DATA_DIR=/data/botree/milvus

MINERU_IMAGE=mineru:latest
MINERU_CONTAINER_NAME=botree-mineru
MINERU_PORT=8000
MINERU_USE_GPU=false
MINERU_OUTPUT_DATA_DIR=/data/botree/mineru_output
MINERU_MODEL_CACHE_DIR=/data/botree/models/mineru_cache

UPLOADS_HOST_DIR=/data/botree/uploads
DERIVED_HOST_DIR=/data/botree/derived
PAGE_INDEX_HOST_DIR=/data/botree/page_index
MODELS_HOST_DIR=/data/botree/models
LOGS_HOST_DIR=/data/botree/logs

FRONTEND_PUBLISH_DIR=/data/botree/frontend/current
BACKUP_MYSQL_DIR=/data/botree/backups/mysql
BACKUP_FILES_DIR=/data/botree/backups/files

FRONTEND_BUILD_IMAGE=node:20-bookworm-slim
VITE_API_BASE_URL=/api
VITE_APP_TITLE=Botree Knowledge OS

BACKEND_ENV_FILE=deploy/env/backend.env
