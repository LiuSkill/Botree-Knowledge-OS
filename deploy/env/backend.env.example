APP_NAME=Botree Knowledge OS
APP_ENV=trial
DEBUG=false
API_PREFIX=/api
HOST=0.0.0.0
PORT=8888
CORS_ALLOW_ORIGINS=http://127.0.0.1,http://localhost

ALLOW_SQLITE_FALLBACK=false
MYSQL_HOST=botree-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=botree_trial
MYSQL_USER=botree
MYSQL_PASSWORD=change-me

REDIS_HOST=botree-redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0
RQ_QUEUE_NAME=botree-index

MINIO_ENDPOINT=botree-minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=graphrag-documents
MINIO_SECURE=false

MILVUS_HOST=botree-milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=botree_collection
EMBEDDING_DIM=1024

MINERU_BASE_URL=http://botree-mineru:8000
MINERU_PARSE_PATH=/file_parse
MINERU_TASK_SUBMIT_PATH=/tasks
MINERU_TASK_TIMEOUT_SECONDS=300
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_HTTP_TIMEOUT_SECONDS=30
MINERU_OUTPUT_HOST_DIR=/app/storage/mineru_output
MINERU_OUTPUT_CONTAINER_DIR=/workspace/output
LIBREOFFICE_BINARY=soffice
LIBREOFFICE_TIMEOUT_SECONDS=180
LIBREOFFICE_WORK_DIR=/app/storage/derived

OPENAI_COMPATIBLE_BASE_URL=https://example.com/compatible-mode/v1
OPENAI_API_KEY=change-me
LLM_PROVIDER=qwen_api
LLM_BASE_URL=https://example.com/compatible-mode/v1
LLM_API_KEY=change-me
LLM_MODEL=qwen3.7-max
LLM_TIMEOUT_SECONDS=60
INTENT_LLM_MODEL=qwen3.5-flash
PLANNER_LLM_MODEL=qwen3.5-flash
EVIDENCE_JUDGE_FAST_MODEL=qwen3.5-flash
EVIDENCE_JUDGE_MODEL=qwen3.5-plus
EVIDENCE_JUDGE_TIMEOUT_SECONDS=15
ANSWER_LLM_MODEL=qwen3.5-plus
ANALYSIS_LLM_MODEL=qwen3.7-max
VISION_LLM_PROVIDER=qwen_api
VISION_LLM_BASE_URL=https://example.com/compatible-mode/v1
VISION_LLM_API_KEY=change-me
VISION_LLM_MODEL=qwen3.5-plus
VISION_LLM_TIMEOUT_SECONDS=90
VISION_LLM_MAX_IMAGES=8
VISION_LLM_MAX_IMAGE_BYTES=8388608

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=/app/models/Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
EMBEDDING_TIMEOUT_SECONDS=60

RERANKER_PROVIDER=local
RERANKER_MODEL=/app/models/bge-reranker-v2-m3
RERANKER_API_BASE=
RERANKER_API_KEY=
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_TIMEOUT_SECONDS=15

JWT_SECRET_KEY=please-replace-with-a-random-32-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

UPLOAD_DIR=/app/storage/uploads
PAGE_INDEX_DIR=/app/storage/page_index
RIPGREP_BINARY=rg
RIPGREP_TIMEOUT_MS=1500
RETRIEVAL_RETRIEVER_TIMEOUT_MS=8000
RETRIEVAL_MILVUS_TIMEOUT_MS=15000
RETRIEVAL_TOTAL_BUDGET_MS=18000
RETRIEVAL_RETRY_BUDGET_MS=6000
RETRIEVAL_MIN_STAGE_BUDGET_MS=1200
RETRIEVAL_MIN_RETRY_BUDGET_MS=1500
RETRIEVAL_MAX_SUB_QUERIES=2
RETRIEVAL_MAX_RETRY_QUERIES=2
RETRIEVAL_MAX_RETRY_RETRIEVERS=2
RETRIEVAL_PAGE_INDEX_CANDIDATE_LIMIT=10
RETRIEVAL_PAGE_INDEX_ROW_LIMIT=240
RETRIEVAL_RIPGREP_CANDIDATE_LIMIT=10
RETRIEVAL_RIPGREP_ROW_LIMIT=180
RETRIEVAL_RIPGREP_PATTERN_LIMIT=8
RETRIEVAL_RIPGREP_MAX_COUNT_PER_FILE=8
RETRIEVAL_TRACE_ENABLED=true
PROJECT_CHAT_INCLUDE_INDUSTRY_KNOWLEDGE=false

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-before-first-start
DEFAULT_ADMIN_REAL_NAME=系统管理员
